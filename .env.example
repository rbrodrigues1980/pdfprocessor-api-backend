# ============================================
# PDF Processor API - Environment Variables
# ============================================
# Para testar na maquina de outro PC com as MESMAS credenciais que voce usa localmente:
#   copie o seu .env (da raiz do projeto) para a pasta do projeto na maquina do amigo.
# Se nao tiver o .env do projeto, copie este arquivo para .env e preencha abaixo.

# MongoDB Atlas URI - OBRIGATORIO substituir pela sua URI real do Atlas.
# No Atlas: Cluster > Connect > Drivers > copie a connection string e troque <password> pela senha.
#
# IMPORTANTE - Ambientes:
#   Produção (Cloud Run):    banco "pdfprocessor"      (este é o padrão para deploy)
#   Desenvolvimento (local): banco "pdfprocessor-hml"   (altere no seu .env local)
#
# Para desenvolvimento local, copie este arquivo para .env e troque
# "pdfprocessor" por "pdfprocessor-hml" na URI abaixo.
# Veja docs/BANCO_DADOS_HML.md para mais detalhes.
SPRING_DATA_MONGODB_URI=mongodb+srv://user:password@SEU-CLUSTER.mongodb.net/pdfprocessor?retryWrites=true&w=majority

# JWT Configuration
JWT_SECRET=your-super-secret-key-minimum-256-bits-for-hs256
JWT_EXPIRATION=900000
JWT_REFRESH_EXPIRATION=2592000000

# MongoDB Local (apenas se usar profile "with-mongodb")
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=admin123

# CORS - Origens extras para produção (separadas por vírgula)
# Em Cloud Run, defina para a URL do seu frontend
# APP_CORS_EXTRA_ORIGINS=https://meu-frontend.us-central1.run.app,https://meudominio.com

# Google Cloud / Gemini AI (para PDFs escaneados e extração inteligente)
# Documentação completa: docs/API_GEMINI_AI.md
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Modelos Gemini (opcional - valores padrão já configurados no application.yml)
# GEMINI_MODEL=gemini-2.5-flash           # Modelo principal (rápido e barato)
# GEMINI_FALLBACK_MODEL=gemini-2.5-pro    # Modelo fallback (mais preciso, mais caro)
# GEMINI_LOCATION=us-central1             # Região do Vertex AI
